{
  "name": "ruil-cli",
  "version": "1.0.0",
  "description": "RUIL — The unified CLI to install components from multiple React UI libraries (shadcn, MUI, Chakra, etc.)",
  "type": "module",
  "bin": {
    "ruil": "./bin/ruil.js"
  },
  "scripts": {
    "dev": "node bin/ruil.js"
  },
  "private": false,
  "files": ["bin", "src", "README.md"],
  "keywords": [
    "react",
    "ui",
    "components",
    "cli",
    "shadcn",
    "mui",
    "chakra",
    "tailwind",
    "nextui",
    "daisyui",
    "mantine",
    "antd"
  ],
  "author": "Sumit Adhikari",
  "license": "MIT",
  "homepage": "https://ruil.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/ruil-cli"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.3.0",
    "ora": "^8.0.1"
  }
}